{
  "name": "developer-box",
  "version": "0.1.0",
  "description": "Developer toolbox desktop app for macOS and Windows",
  "packageManager": "pnpm@10.20.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron electron/main.cjs\"",
    "build:renderer": "vite build",
    "build": "pnpm run build:renderer && electron-builder",
    "pack": "pnpm run build:renderer && electron-builder --dir"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fhyuncai/developer-box.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/fhyuncai/developer-box/issues"
  },
  "homepage": "https://github.com/fhyuncai/developer-box#readme",
  "build": {
    "appId": "com.developerbox.app",
    "productName": "Developer Box",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "antd": "^6.3.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^18.19.123",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^7.6.0",
    "cross-env": "^7.0.3",
    "electron": "^27.3.11",
    "electron-builder": "^24.13.3",
    "sass": "^1.99.0",
    "typescript": "^5.4.5",
    "vite": "^4.5.14",
    "wait-on": "^6.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
